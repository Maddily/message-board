<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Read a message from <%= message.user %> posted on our community message board: <%= message.text.substring(0, 120) %>..."
    />
    <link rel="stylesheet" href="/message.css" />
    <%- include("commonLinks") %>
    <title>View Message from <%= message.user %> | Message Board</title>
  </head>
  <body>
    <div class="board-frame">
      <div class="board-surface">
        <h1 class="visually-hidden">View Message from <%= message.user %></h1>
        <article
          class="message"
          style="background-color: <%= generateRandomPastelColor() %>"
        >
          <div
            class="pin"
            style="background-color: <%= generateRandomColor() %>"
          ></div>
          <p class="name"><%= message.user %></p>
          <p class="text"><%= message.text %></p>
          <time class="date-and-time"><%= message.added %></time>
        </article>
        <%- include("homeButton") %>
      </div>
      <%- include("postButton") %>
    </div>
  </body>
</html>
